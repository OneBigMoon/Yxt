.tech-page {
  position: relative;
  min-height: 100vh;
  background: linear-gradient(180deg, #f5f5f5 0%, #f8f1e8 100%);
  padding-bottom: 260rpx;
  color: #231f1a;
}

.tech-watermark {
  position: absolute;
  right: -140rpx;
  top: 220rpx;
  width: 420rpx;
  height: 420rpx;
  opacity: 0.045;
  pointer-events: none;
}

.tech-hero {
  position: relative;
  z-index: 1;
  padding: 72rpx 32rpx 40rpx;
  border-radius: 0 0 34rpx 34rpx;
  overflow: hidden;
  background: linear-gradient(145deg, #3f6131, #6f864f);
  color: #fffdf8;
}

.tech-hero::after {
  content: '';
  position: absolute;
  right: -90rpx;
  bottom: -110rpx;
  width: 320rpx;
  height: 320rpx;
  background: rgba(255, 253, 248, 0.16);
  border-radius: 50%;
  opacity: 0.12;
  pointer-events: none;
}

.tech-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 28rpx;
}

.tech-kicker,
.tech-title {
  display: block;
}

.tech-kicker {
  color: rgba(255, 253, 248, 0.74);
  font-size: 24rpx;
  font-weight: 600;
}

.tech-title {
  margin-top: 8rpx;
  color: #fffdf8;
  font-size: 42rpx;
  font-weight: 700;
}

.tech-date {
  padding: 10rpx 18rpx;
  border-radius: 26rpx;
  background: rgba(255, 253, 248, 0.1);
  color: #fffdf8;
  font-size: 24rpx;
  font-weight: 600;
}

.stats-section {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 34rpx;
  border: 1rpx solid rgba(255, 253, 248, 0.16);
  border-radius: 24rpx;
  background: rgba(255, 253, 248, 0.08);
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 60rpx;
}

.stat-num {
  font-size: 60rpx;
  font-weight: bold;
  color: #fffdf8;
}

.stat-label {
  font-size: 24rpx;
  color: rgba(255, 253, 248, 0.76);
  margin-top: 8rpx;
}

.stat-divider {
  width: 2rpx;
  height: 60rpx;
  background: rgba(255, 253, 248, 0.18);
}

.scan-section {
  position: relative;
  z-index: 2;
  padding: 28rpx 32rpx 24rpx;
  margin-top: -18rpx;
  margin-bottom: 24rpx;
}

.scan-button {
  background: #5a7846 !important;
  border-color: #5a7846 !important;
  color: #fffdf8 !important;
  box-shadow: 0 12rpx 26rpx rgba(90, 120, 70, 0.2);
}

.list-section {
  position: relative;
  z-index: 1;
  padding: 0 32rpx;
}

.section-title {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  font-size: 32rpx;
  font-weight: bold;
  color: #231f1a;
  margin-bottom: 20rpx;
}

.section-subtitle {
  font-size: 24rpx;
  font-weight: 400;
  color: #8a8176;
}

.appointment-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.appointment-item {
  padding: 28rpx;
  margin-bottom: 0;
  border: 1rpx solid rgba(100, 70, 40, 0.08);
  background: #fffdf8;
  border-radius: 20rpx;
}

.apt-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.apt-services {
  font-size: 30rpx;
  font-weight: bold;
  color: #231f1a;
  flex: 1;
}

.status-pending {
  color: #ff976a;
  background: rgba(255, 151, 106, 0.1);
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
}

.status-completed {
  color: #5a7846;
  background: rgba(90, 120, 70, 0.12);
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
}

.apt-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.apt-row {
  display: flex;
  align-items: center;
  font-size: 26rpx;
  color: #6d6358;
  gap: 8rpx;
}

.apt-actions {
  margin-top: 16rpx;
  display: flex;
  justify-content: flex-end;
}

.loading {
  display: flex;
  justify-content: center;
  padding: 40rpx;
}


/* P0 verification polish */
.tech-hero {
  box-shadow: 0 12rpx 32rpx rgba(35, 31, 26, 0.10);
}

.scan-button {
  min-height: 96rpx;
  line-height: 96rpx;
  font-size: 32rpx;
  font-weight: 700;
}

.scan-helper {
  margin-top: 16rpx;
  color: #7a7165;
  font-size: 24rpx;
  line-height: 1.55;
  text-align: center;
}

.scan-code-entry {
  margin-top: 18rpx;
  color: #5a7846;
  font-size: 28rpx;
  font-weight: 800;
  text-align: center;
}

.appointment-item {
  border: 2rpx solid rgba(100, 70, 40, 0.08);
  box-shadow: 0 10rpx 26rpx rgba(93, 71, 45, 0.06);
}

.verify-button {
  min-width: 168rpx;
  min-height: 80rpx;
  font-size: 28rpx;
}


.section-actions {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.section-link {
  color: #5a7846;
  font-size: 25rpx;
  font-weight: 800;
}
