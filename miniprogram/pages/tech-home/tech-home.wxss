.tech-page {
  padding-bottom: 120rpx;
}

.stats-section {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 40rpx;
  background: linear-gradient(180deg, #07c160 0%, #4facfe 100%);
  margin-bottom: 24rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 60rpx;
}

.stat-num {
  font-size: 60rpx;
  font-weight: bold;
  color: #fff;
}

.stat-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 8rpx;
}

.stat-divider {
  width: 2rpx;
  height: 60rpx;
  background: rgba(255, 255, 255, 0.3);
}

.scan-section {
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.list-section {
  padding: 0 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.appointment-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.appointment-item {
  padding: 24rpx;
  margin-bottom: 0;
}

.apt-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.apt-services {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  flex: 1;
}

.status-pending {
  color: #ff976a;
  background: rgba(255, 151, 106, 0.1);
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
}

.status-completed {
  color: #07c160;
  background: rgba(7, 193, 96, 0.1);
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
}

.apt-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.apt-row {
  display: flex;
  align-items: center;
  font-size: 26rpx;
  color: #666;
  gap: 8rpx;
}

.loading {
  display: flex;
  justify-content: center;
  padding: 40rpx;
}
