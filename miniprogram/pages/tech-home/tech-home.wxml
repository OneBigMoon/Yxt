<view class="tech-page">
  <!-- 顶部统计 -->
  <view class="stats-section">
    <view class="stat-item">
      <text class="stat-num">{{stats.pending}}</text>
      <text class="stat-label">待核销</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <text class="stat-num">{{stats.completed}}</text>
      <text class="stat-label">已核销</text>
    </view>
  </view>

  <!-- 扫码按钮 -->
  <view class="scan-section">
    <van-button
      type="primary"
      size="large"
      round
      block
      icon="scan"
      bindtap="scanCode"
    >
      扫码核销
    </van-button>
  </view>

  <!-- 今日预约列表 -->
  <view class="list-section">
    <view class="section-title">今日预约</view>

    <view class="appointment-list">
      <view
        class="appointment-item card"
        wx:for="{{appointments}}"
        wx:key="_id"
      >
        <view class="apt-header">
          <text class="apt-services">{{item.service_names}}</text>
          <text class="status-{{item.status}}">
            {{item.status === 'pending' ? '待核销' : (item.status === 'cancelled' ? '已取消' : '已核销')}}
          </text>
        </view>
        <view class="apt-info">
          <view class="apt-row">
            <van-icon name="clock-o" size="14" color="#999" />
            <text>{{item.start_time}} - {{item.end_time}}</text>
          </view>
          <view class="apt-row">
            <van-icon name="user-o" size="14" color="#999" />
            <text>{{item.patient_name || '未知用户'}}</text>
          </view>
        </view>
      </view>

      <van-empty
        wx:if="{{appointments.length === 0 && !loading}}"
        description="今日暂无预约"
        image="search"
      />
    </view>
  </view>

  <!-- 底部导航 -->
  <van-tabbar
    active="{{activeTab}}"
    bind:change="onTabChange"
    active-color="#1989fa"
  >
    <van-tabbar-item icon="todo-list-o" name="home">今日预约</van-tabbar-item>
    <van-tabbar-item icon="records" name="records">核销记录</van-tabbar-item>
  </van-tabbar>

  <!-- 加载状态 -->
  <van-loading
    wx:if="{{loading}}"
    class="loading"
    type="spinner"
    size="24"
  >
    加载中...
  </van-loading>
</view>
