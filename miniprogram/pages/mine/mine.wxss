.mine-page {
  position: relative;
  min-height: 100vh;
  padding: 34rpx 0 calc(144rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  color: #3b2e2a;
  background-color: #fdfbf7;
  background-image: linear-gradient(180deg, #fdfbf7 0%, #f8f1e8 100%);
}

.page-logo-watermark {
  position: absolute;
  z-index: 0;
  width: 460rpx;
  height: 460rpx;
  opacity: 0.055;
  pointer-events: none;
}

.page-logo-watermark--top {
  right: -150rpx;
  top: 160rpx;
}

.page-logo-watermark--bottom {
  left: -160rpx;
  bottom: 170rpx;
  opacity: 0.04;
}

.member-titlebar {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 42rpx 26rpx;
}

.member-title-left {
  display: flex;
  align-items: center;
  min-width: 0;
  gap: 14rpx;
}

.member-title-logo {
  width: 50rpx;
  height: 50rpx;
  flex-shrink: 0;
  border-radius: 18rpx;
  background: #fffdf8;
  box-shadow: 0 8rpx 18rpx rgba(59, 46, 42, 0.08);
}

.member-title {
  font-size: 34rpx;
  font-weight: 800;
  color: #231f1a;
}

.member-badge {
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: #edf4e8;
  color: #5a7846;
  font-size: 24rpx;
  font-weight: 700;
}

.member-card {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 190rpx;
  margin: 0 42rpx 28rpx;
  padding: 34rpx 34rpx 32rpx;
  overflow: hidden;
  box-sizing: border-box;
  border-radius: 28rpx;
  background: linear-gradient(145deg, #4d753b 0%, #6e8a53 100%);
  box-shadow: 0 16rpx 32rpx rgba(63, 97, 49, 0.22);
}

.member-card::after {
  content: '';
  position: absolute;
  right: -86rpx;
  top: -80rpx;
  width: 300rpx;
  height: 300rpx;
  border-radius: 50%;
  background: rgba(255, 253, 248, 0.08);
}

.member-card::before {
  content: '';
  position: absolute;
  right: 96rpx;
  bottom: -114rpx;
  width: 280rpx;
  height: 280rpx;
  background: rgba(255, 253, 248, 0.12);
  border-radius: 50%;
  opacity: 0.08;
  pointer-events: none;
}

.member-copy {
  position: relative;
  z-index: 1;
  min-width: 0;
}

.member-phone {
  display: block;
  max-width: 430rpx;
  font-size: 44rpx;
  font-weight: 800;
  line-height: 1.18;
  letter-spacing: 2rpx;
  color: #fffdf8;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.member-status {
  display: block;
  margin-top: 14rpx;
  font-size: 27rpx;
  line-height: 1.4;
  color: rgba(255, 253, 248, 0.82);
}

.member-logo-action {
  position: relative;
  z-index: 1;
  width: 112rpx;
  height: 112rpx;
  flex-shrink: 0;
  overflow: hidden;
  padding: 12rpx;
  box-sizing: border-box;
  border-radius: 28rpx;
  background: rgba(255, 253, 248, 0.92);
  box-shadow: 0 10rpx 24rpx rgba(35, 31, 26, 0.14);
}

.member-logo-mark {
  width: 100%;
  height: 100%;
  opacity: 0.9;
}

.profile-menu,
.clinic-menu {
  position: relative;
  z-index: 1;
  margin: 0 42rpx;
}

.menu-row {
  min-height: 128rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 22rpx;
  box-sizing: border-box;
  border: 1rpx solid rgba(100, 70, 40, 0.08);
  border-radius: 24rpx;
  background: rgba(255, 253, 248, 0.96);
  box-shadow: 0 10rpx 24rpx rgba(59, 46, 42, 0.06);
}

.menu-row:last-child {
  margin-bottom: 22rpx;
}

.menu-row:active {
  background: #fbf7ef;
}

.menu-row--soft {
  background: rgba(253, 251, 247, 0.55);
}

.menu-left {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.menu-icon {
  width: 66rpx;
  height: 66rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 20rpx;
  background: #edf4e8;
  color: #5a7846;
  font-size: 26rpx;
  font-weight: 800;
}

.menu-title {
  font-size: 32rpx;
  font-weight: 800;
  line-height: 1.3;
  color: #3b2e2a;
}

.menu-right {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  gap: 10rpx;
  color: #7a6c66;
  font-size: 25rpx;
}

.menu-stack {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.menu-desc {
  display: block;
  max-width: 520rpx;
  margin-top: 8rpx;
  font-size: 26rpx;
  line-height: 1.4;
  color: #7a6c66;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.menu-phone {
  max-width: 260rpx;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
}

.menu-phone text {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.logout-section {
  position: relative;
  z-index: 1;
  padding: 26rpx 32rpx 30rpx;
}

.logout-btn {
  width: 100%;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid rgba(100, 70, 40, 0.1);
  border-radius: 44rpx;
  background: #fff;
  color: #8a8176;
  font-size: 28rpx;
  line-height: 1;
  padding: 0;
  text-align: center;
  -webkit-appearance: none;
}

.logout-btn::after {
  border: none;
}


.member-card-arrow {
  position: relative;
  z-index: 2;
  flex-shrink: 0;
  margin-left: 12rpx;
}

.facility-section {
  position: relative;
  z-index: 1;
  margin: 8rpx 42rpx 28rpx;
}

.facility-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 18rpx;
}

.facility-title {
  font-size: 34rpx;
  font-weight: 900;
  color: #231f1a;
}

.facility-more {
  font-size: 25rpx;
  font-weight: 800;
  color: #7a7165;
}

.facility-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 14rpx;
}

.facility-chip {
  min-width: 0;
  min-height: 78rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  box-sizing: border-box;
  padding: 12rpx 8rpx;
  border: 1rpx solid rgba(90, 120, 70, 0.13);
  border-radius: 999rpx;
  background: rgba(255, 253, 248, 0.94);
  color: #315c33;
  font-size: 24rpx;
  font-weight: 900;
  white-space: nowrap;
}
