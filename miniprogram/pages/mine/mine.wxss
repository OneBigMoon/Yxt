.mine-page {
  padding-bottom: 40rpx;
}

.user-section {
  background: linear-gradient(180deg, #1989fa 0%, #4facfe 100%);
  padding: 60rpx 30rpx 40rpx;
}

.user-info {
  display: flex;
  align-items: center;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.5);
  margin-right: 24rpx;
}

.user-detail {
  flex: 1;
}

.nickname {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
  display: block;
  margin-bottom: 8rpx;
}

.user-id {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.menu-section {
  margin: 24rpx;
  padding: 0;
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 30rpx 24rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-text {
  flex: 1;
  font-size: 30rpx;
  color: #333;
  margin-left: 16rpx;
}

.shop-info {
  padding: 24rpx;
}

.shop-row {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.shop-row:last-child {
  margin-bottom: 0;
}

.shop-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-left: 12rpx;
}

.shop-addr {
  font-size: 24rpx;
  color: #666;
  margin-left: 12rpx;
}

.logout-section {
  margin: 40rpx 24rpx 0;
}

.logout-btn {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 30rpx;
  color: #999;
  background: #fff;
  border: 1rpx solid #e5e5e5;
  border-radius: 12rpx;
}

.logout-btn::after {
  border: none;
}
