<view class="mine-page yxt-page">
  <image class="page-logo-watermark page-logo-watermark--top" src="/images/logo.jpg" mode="aspectFit"></image>
  <image class="page-logo-watermark page-logo-watermark--bottom" src="/images/logo.jpg" mode="aspectFit"></image>

  <view class="member-titlebar">
    <view class="member-title-left">
      <image class="member-title-logo" src="/images/logo.jpg" mode="aspectFit"></image>
      <text class="member-title">会员中心</text>
    </view>
  </view>

  <view class="member-card" bindtap="handleUserTap">
    <view class="member-copy">
      <text class="member-phone">{{isLoggedIn ? (maskedPhone || userDisplayName) : '微信手机号登录'}}</text>
      <text class="member-status">{{isLoggedIn ? '点击此卡进入客户资料' : '登录后自动建立客户档案'}}</text>
    </view>
    <view class="member-logo-action">
      <image class="member-logo-mark" src="/images/logo.jpg" mode="aspectFit" />
    </view>
    <van-icon class="member-card-arrow" name="arrow" size="18" color="rgba(255,253,248,0.78)" />
  </view>

  <view class="profile-menu">
    <view class="menu-row menu-row--soft" bindtap="goMyAppointments">
      <view class="menu-left">
        <view class="menu-icon"><van-icon name="calendar-o" size="19" color="#5a7846" /></view>
        <view class="menu-stack">
          <text class="menu-title">我的预约</text>
          <text class="menu-desc">待到店、已完成、已取消</text>
        </view>
      </view>
      <view class="menu-right">
        <van-icon name="arrow" size="14" color="#d8d1c7" />
      </view>
    </view>
  </view>

  <view class="facility-section" wx:if="{{facilities.length > 0}}">
    <view class="facility-head">
      <view class="title-left">
        <view class="title-mark"></view>
        <text class="facility-title">本店设施</text>
      </view>
      <text class="facility-more">后台配置</text>
    </view>
    <view class="facility-grid">
      <view class="facility-chip" wx:for="{{facilities}}" wx:key="name">
        <van-icon name="{{item.icon}}" size="18" color="#5a7846" />
        <text>{{item.name}}</text>
      </view>
    </view>
  </view>

  <view class="clinic-menu" wx:if="{{businessHourLines.length > 0 || clinicInfo.phone}}">
    <view class="menu-row" wx:if="{{businessHourLines.length > 0}}">
      <view class="menu-left">
        <view class="menu-icon"><van-icon name="clock-o" size="19" color="#5a7846" /></view>
        <view class="menu-stack">
          <text class="menu-title">营业时间</text>
          <text class="menu-desc" wx:for="{{businessHourLines}}" wx:key="day">
            {{item.day}} {{item.time}}
          </text>
        </view>
      </view>
    </view>

    <view class="menu-row" wx:if="{{clinicInfo.phone}}" bindtap="callPhone">
      <view class="menu-left">
        <view class="menu-icon"><van-icon name="phone-o" size="19" color="#5a7846" /></view>
        <text class="menu-title">联系门店</text>
      </view>
      <view class="menu-right menu-phone">
        <text>{{clinicInfo.phone}}</text>
        <van-icon name="phone-o" size="15" color="#7a6c66" />
      </view>
    </view>
  </view>

  <view class="logout-section" wx:if="{{isLoggedIn}}">
    <button class="logout-btn" bindtap="handleLogout">退出登录</button>
  </view>
</view>
