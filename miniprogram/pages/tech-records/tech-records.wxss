.records-page {
  padding: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.record-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.record-item {
  padding: 24rpx;
  margin-bottom: 0;
}

.record-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.record-services {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  flex: 1;
}

.record-time {
  font-size: 24rpx;
  color: #07c160;
}

.record-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.record-row {
  display: flex;
  align-items: center;
  font-size: 26rpx;
  color: #666;
}

.record-row van-icon {
  margin-right: 8rpx;
}

.loading {
  display: flex;
  justify-content: center;
  padding: 40rpx;
}
