<view class="records-page yxt-page yxt-page-with-tabbar">
  <image class="yxt-page-logo top" src="/images/logo.jpg" mode="aspectFit"></image>

  <view class="records-hero yxt-card">
    <text class="records-kicker">核销记录</text>
    <text class="records-title">今日已完成 {{records.length}} 单</text>
    <text class="records-desc">仅展示当前技师今日已核销的预约。</text>
  </view>

  <view class="section-title">记录明细</view>

  <view class="record-list">
    <view
      class="record-item yxt-card"
      wx:for="{{records}}"
      wx:key="_id"
    >
      <view class="record-header">
        <text class="record-services">{{item.service_names}}</text>
        <text class="record-time">{{item.verified_at}}</text>
      </view>
      <view class="record-info">
        <view class="record-row">
          <van-icon name="user-o" size="14" color="#999" />
          <text>{{item.patient_name || '未知用户'}}</text>
        </view>
        <view class="record-row">
          <van-icon name="clock-o" size="14" color="#999" />
          <text>{{item.start_time}} - {{item.end_time}}</text>
        </view>
      </view>
    </view>

    <van-empty
      wx:if="{{records.length === 0 && !loading}}"
      description="今日暂无核销记录"
      image="search"
    />
  </view>

  <!-- 加载状态 -->
  <van-loading
    wx:if="{{loading}}"
    class="loading"
    type="spinner"
    size="24"
  >
    加载中...
  </van-loading>
  <view class="yxt-lite-tabbar">
    <navigator class="yxt-lite-tabbar-item " url="/pages/index/index" open-type="switchTab">
      <van-icon name="wap-home-o" size="22" />
      <text>首页</text>
    </navigator>
    <navigator class="yxt-lite-tabbar-item active" url="/pages/booking/booking" open-type="switchTab">
      <van-icon name="calendar-o" size="22" />
      <text>服务</text>
    </navigator>
    <navigator class="yxt-lite-tabbar-item " url="/pages/mine/mine" open-type="switchTab">
      <van-icon name="user-o" size="22" />
      <text>会员</text>
    </navigator>
  </view>
</view>