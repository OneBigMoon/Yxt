<view class="my-appointments-page">
  <van-tabs active="{{activeTab}}" bind:change="onTabChange" color="#07c160" line-width="60rpx">
    <van-tab title="待核销" name="pending"></van-tab>
    <van-tab title="已完成" name="completed"></van-tab>
    <van-tab title="已取消" name="cancelled"></van-tab>
  </van-tabs>

  <view class="appointment-list">
    <view
      class="appointment-item card"
      wx:for="{{appointments}}"
      wx:key="_id"
      bindtap="viewDetail"
      data-id="{{item._id}}"
    >
      <view class="apt-header">
        <text class="apt-services">{{item.service_names}}</text>
        <text class="status-{{item.status}}">
          {{item.status === 'pending' ? '待核销' : item.status === 'completed' ? '已完成' : '已取消'}}
        </text>
      </view>
      <view class="apt-info">
        <view class="apt-row">
          <van-icon name="clock-o" size="14" color="#999" />
          <text>{{item.date}} {{item.start_time}}-{{item.end_time}}</text>
        </view>
        <view class="apt-row" wx:if="{{item.technician_name}}">
          <van-icon name="user-o" size="14" color="#999" />
          <text>技师：{{item.technician_name}}</text>
        </view>
      </view>
    </view>

    <van-empty
      wx:if="{{appointments.length === 0 && !loading}}"
      description="暂无预约记录"
      image="search"
    />
  </view>

  <van-loading wx:if="{{loading}}" class="loading" type="spinner" size="24">加载中...</van-loading>
</view>
