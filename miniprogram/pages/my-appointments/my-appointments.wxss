.my-appointments-page {
  min-height: 100vh;
  background: #f5f5f5;
}

.appointment-list {
  padding: 20rpx 24rpx;
}

.appointment-item {
  padding: 24rpx;
  margin-bottom: 16rpx;
}

.apt-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.apt-services {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  flex: 1;
}

.status-pending {
  color: #ff976a;
  background: rgba(255, 151, 106, 0.1);
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
}

.status-completed {
  color: #07c160;
  background: rgba(7, 193, 96, 0.1);
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
}

.status-cancelled {
  color: #999;
  background: rgba(153, 153, 153, 0.1);
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
}

.apt-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.apt-row {
  display: flex;
  align-items: center;
  font-size: 26rpx;
  color: #666;
}

.loading {
  display: flex;
  justify-content: center;
  padding: 40rpx;
}
