.profile-page {
  padding: 54rpx 40rpx 48rpx;
  padding-bottom: 270rpx;
  box-sizing: border-box;
}

.profile-header {
  position: relative;
  z-index: 1;
  margin-bottom: 34rpx;
}

.profile-title {
  display: block;
  font-size: 44rpx;
  font-weight: 700;
  color: #231f1a;
  line-height: 1.25;
}

.profile-subtitle {
  display: block;
  margin-top: 12rpx;
  font-size: 28rpx;
  line-height: 1.45;
  color: #7a7165;
}

.profile-form {
  position: relative;
  padding: 34rpx;
  margin-bottom: 46rpx;
}

.avatar-section {
  margin-bottom: 42rpx;
}

.avatar-btn {
  width: 100%;
  min-height: 132rpx;
  display: flex;
  align-items: center;
  background: #fbf7ef;
  border: 1rpx solid rgba(100, 70, 40, 0.08);
  border-radius: 20rpx;
  padding: 22rpx;
  margin: 18rpx 0 0;
  line-height: 1;
  text-align: left;
  -webkit-appearance: none;
}

.avatar-btn::after {
  border: none;
}

.avatar-img {
  width: 104rpx;
  height: 104rpx;
  border-radius: 50%;
  border: 4rpx solid #edf2e8;
  box-shadow: 0 8rpx 24rpx rgba(90, 120, 70, 0.12);
}

.avatar-tip {
  margin-left: 24rpx;
  font-size: 29rpx;
  color: #7a7165;
}

.input-section {
  margin-bottom: 10rpx;
}

.input-label {
  font-size: 30rpx;
  font-weight: 700;
  color: #3b2e2a;
  margin-bottom: 18rpx;
}

.nickname-input {
  height: 96rpx;
  box-sizing: border-box;
  border: 2rpx solid rgba(100, 70, 40, 0.1);
  border-radius: 18rpx;
  padding: 0 24rpx;
  font-size: 32rpx;
  background: #fffdf8;
}

.nickname-input:focus {
  border-color: #5a7846;
}

.submit-section {
  position: fixed;
  left: 0;
  right: 0;
  bottom: calc(146rpx + env(safe-area-inset-bottom));
  z-index: 30;
  box-sizing: border-box;
  padding: 20rpx 40rpx;
}
