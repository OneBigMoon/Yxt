.booking-page {
  padding-bottom: 160rpx;
}

.steps {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx 60rpx;
  background: #fff;
  margin-bottom: 20rpx;
}

.step {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.step-num {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #ddd;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  margin-bottom: 8rpx;
}

.step.active .step-num {
  background: #1989fa;
}

.step-text {
  font-size: 24rpx;
  color: #999;
}

.step.active .step-text {
  color: #1989fa;
}

.step-line {
  flex: 1;
  height: 4rpx;
  background: #ddd;
  margin: 0 20rpx;
  margin-bottom: 30rpx;
}

.step-line.active {
  background: #1989fa;
}

.step-content {
  padding: 24rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 24rpx;
}

.service-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.service-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  background: #fff;
  border-radius: 12rpx;
  border: 2rpx solid #eee;
}

.service-item.selected {
  border-color: #1989fa;
  background: #f0f8ff;
}

.service-info {
  flex: 1;
}

.service-name {
  font-size: 30rpx;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
}

.service-duration {
  font-size: 24rpx;
  color: #999;
}

.selected-date {
  padding: 24rpx;
  background: #fff;
  border-radius: 12rpx;
  margin-bottom: 24rpx;
  text-align: center;
  font-size: 30rpx;
  color: #333;
}

.slots-container {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.slot-item {
  width: calc(50% - 8rpx);
  padding: 24rpx;
  background: #fff;
  border-radius: 12rpx;
  border: 2rpx solid #eee;
  text-align: center;
}

.slot-item.disabled {
  background: #f5f5f5;
  opacity: 0.6;
}

.slot-item.selected {
  border-color: #1989fa;
  background: #f0f8ff;
}

.slot-time {
  font-size: 30rpx;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
}

.slot-item.disabled .slot-time {
  color: #999;
}

.slot-count {
  font-size: 22rpx;
  color: #999;
}

.slot-item.selected .slot-count {
  color: #1989fa;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 24rpx;
  background: #fff;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.05);
  z-index: 100;
}

.selected-info {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.success-popup {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx;
}

.success-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin: 24rpx 0 16rpx;
}

.success-desc {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 40rpx;
}

.success-btn {
  width: 100%;
}
