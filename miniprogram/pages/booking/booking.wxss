.booking-page {
  padding-bottom: 0;
}

.loading-page {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 300rpx 0;
}

.full-page {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 60rpx;
}

.full-icon {
  margin-bottom: 40rpx;
}

.full-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 24rpx;
}

.full-message {
  font-size: 28rpx;
  color: #999;
  text-align: center;
}

.closure-page {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 60rpx;
}

.closure-icon {
  margin-bottom: 40rpx;
}

.closure-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 24rpx;
}

.closure-reason {
  font-size: 30rpx;
  color: #ff976a;
  margin-bottom: 24rpx;
  text-align: center;
}

.closure-tip {
  font-size: 26rpx;
  color: #999;
}

.steps {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx 60rpx;
  background: #fff;
  margin-bottom: 20rpx;
}

.step {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.step-num {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #ddd;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  margin-bottom: 8rpx;
}

.step.active .step-num {
  background: #07c160;
}

.step-text {
  font-size: 24rpx;
  color: #999;
}

.step.active .step-text {
  color: #07c160;
}

.step-line {
  flex: 1;
  height: 4rpx;
  background: #ddd;
  margin: 0 20rpx;
  margin-bottom: 30rpx;
}

.step-line.active {
  background: #07c160;
}

.step-content {
  padding: 24rpx;
  padding-bottom: 200rpx;
}

.availability-msg {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 20rpx;
  background: #fff3e0;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #ff976a;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.section-tip {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 24rpx;
}

.service-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.service-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  background: #fff;
  border-radius: 12rpx;
  border: 2rpx solid #eee;
}

.service-item.selected {
  border-color: #07c160;
  background: #f0f8ff;
}

.service-img {
  width: 100rpx;
  height: 100rpx;
  border-radius: 12rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.service-info {
  flex: 1;
}

.service-name {
  font-size: 30rpx;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
}

.service-duration {
  font-size: 24rpx;
  color: #999;
}

.date-picker-area {
  padding: 40rpx 24rpx;
  background: #fff;
  border-radius: 12rpx;
  text-align: center;
  margin-bottom: 24rpx;
}

.date-picker-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}

.date-picker-text {
  font-size: 30rpx;
  color: #07c160;
}

.selected-date {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  font-size: 30rpx;
  color: #333;
  padding: 24rpx;
  background: #fff;
  border-radius: 12rpx;
  margin-bottom: 24rpx;
}

.change-date-tip {
  font-size: 24rpx;
  color: #07c160;
}

.date-hint {
  padding: 40rpx 0;
}

.reselect {
  font-size: 26rpx;
  color: #07c160;
}

.slots-container {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  width: 100%;
}

.slot-item {
  flex: 0 0 calc(50% - 8rpx);
  box-sizing: border-box;
  padding: 20rpx 10rpx;
  background: #fff;
  border-radius: 12rpx;
  border: 2rpx solid #eee;
  text-align: center;
}

.slot-item.disabled {
  background: #f5f5f5;
  opacity: 0.6;
}

.slot-item.selected {
  border-color: #07c160;
  background: #f0f8ff;
}

.slot-time {
  font-size: 30rpx;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
}

.slot-item.disabled .slot-time {
  color: #999;
}

.slot-count {
  font-size: 22rpx;
  color: #999;
}

.slot-item.selected .slot-count {
  color: #07c160;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 20rpx;
  padding: 20rpx 24rpx;
  background: #fff;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.05);
  z-index: 100;
}

.bottom-bar .van-button {
  flex: 1;
}

.selected-info {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.success-popup {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx;
}

.success-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin: 24rpx 0 16rpx;
}

.success-desc {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 40rpx;
}

.success-btn {
  width: 100%;
}
