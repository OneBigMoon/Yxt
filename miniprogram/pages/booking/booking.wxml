<view class="booking-page">
  <!-- 步骤条 -->
  <view class="steps">
    <view class="step {{currentStep >= 1 ? 'active' : ''}}">
      <view class="step-num">1</view>
      <text class="step-text">选择服务</text>
    </view>
    <view class="step-line {{currentStep >= 2 ? 'active' : ''}}"></view>
    <view class="step {{currentStep >= 2 ? 'active' : ''}}">
      <view class="step-num">2</view>
      <text class="step-text">选择日期</text>
    </view>
    <view class="step-line {{currentStep >= 3 ? 'active' : ''}}"></view>
    <view class="step {{currentStep >= 3 ? 'active' : ''}}">
      <view class="step-num">3</view>
      <text class="step-text">选择时段</text>
    </view>
  </view>

  <!-- 步骤1：选择服务 -->
  <view class="step-content" wx:if="{{currentStep === 1}}">
    <view class="section-title">请选择服务项目（可多选）</view>
    <view class="service-list">
      <view
        class="service-item {{item.selected ? 'selected' : ''}}"
        wx:for="{{services}}"
        wx:key="_id"
        bindtap="toggleService"
        data-index="{{index}}"
      >
        <image
          class="service-img"
          src="{{item.imageUrl || item.image_url || '/images/default-article.png'}}"
          mode="aspectFill"
        />
        <view class="service-info">
          <text class="service-name">{{item.name}}</text>
          <text class="service-duration">{{item.duration}}分钟</text>
        </view>
        <van-icon
          name="{{item.selected ? 'passed' : 'circle'}}"
          color="{{item.selected ? '#1989fa' : '#ddd'}}"
          size="24"
        />
      </view>
    </view>

    <view class="bottom-bar" wx:if="{{selectedServices.length > 0}}">
      <view class="selected-info">
        已选 {{selectedServices.length}} 项，总时长 {{totalDuration}} 分钟
      </view>
      <van-button type="primary" round bindtap="nextStep">下一步</van-button>
    </view>
  </view>

  <!-- 步骤2：选择日期 -->
  <view class="step-content" wx:if="{{currentStep === 2}}">
    <view class="section-title">请选择预约日期</view>

    <view class="selected-date" wx:if="{{selectedDate}}" bindtap="openCalendar">
      <text>已选日期：{{selectedDate}}</text>
      <text class="change-date-tip">点击修改</text>
    </view>

    <view class="date-hint" wx:if="{{!selectedDate && !showCalendar}}">
      <van-button type="primary" plain round block bindtap="openCalendar">选择日期</van-button>
    </view>

    <van-calendar
      show="{{showCalendar}}"
      show-confirm="{{false}}"
      bind:close="onCalendarClose"
      bind:select="onCalendarDayClick"
      min-date="{{minDate}}"
      max-date="{{maxDate}}"
      title="选择日期"
      color="#1989fa"
      formatter="{{calendarFormatter}}"
    />

    <view class="bottom-bar">
      <van-button plain bindtap="prevStep">上一步</van-button>
      <van-button
        type="primary"
        round
        bindtap="nextStep"
        disabled="{{!selectedDate}}"
      >
        下一步
      </van-button>
    </view>
  </view>

  <!-- 步骤3：选择时段 -->
  <view class="step-content" wx:if="{{currentStep === 3}}">
    <view class="section-title">请选择预约时段</view>

    <van-loading wx:if="{{slotsLoading}}" type="spinner" size="24">
      计算可用时段中...
    </van-loading>

    <view class="slots-container" wx:if="{{!slotsLoading}}">
      <view
        class="slot-item {{item.selected ? 'selected' : ''}}"
        wx:for="{{timeSlots}}"
        wx:key="time"
        bindtap="selectSlot"
        data-index="{{index}}"
      >
        <text class="slot-time">{{item.time}}</text>
      </view>

      <van-empty
        wx:if="{{timeSlots.length === 0}}"
        description="该日期暂无可用时段"
        image="search"
      />
    </view>

    <view class="bottom-bar">
      <van-button plain bindtap="prevStep">上一步</van-button>
      <van-button
        type="primary"
        round
        bindtap="confirmBooking"
        disabled="{{!selectedSlot}}"
        loading="{{bookingLoading}}"
      >
        确认预约
      </van-button>
    </view>
  </view>

  <!-- 预约成功弹窗 -->
  <van-popup
    show="{{showSuccess}}"
    closeable
    round
    position="center"
    custom-style="padding: 40rpx; width: 80%;"
    bind:close="onSuccessClose"
  >
    <view class="success-popup">
      <van-icon name="passed" size="80" color="#07c160" />
      <text class="success-title">预约成功</text>
      <text class="success-desc">请到预约列表查看</text>
      <van-button
        type="primary"
        round
        block
        bindtap="goToAppointments"
        class="success-btn"
      >
        查看预约
      </van-button>
    </view>
  </van-popup>
</view>
