.article-detail-page {
  padding: 24rpx;
  background: #fff;
  min-height: 100vh;
}

.article-header {
  margin-bottom: 30rpx;
}

.article-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  display: block;
  margin-bottom: 16rpx;
  line-height: 1.4;
}

.article-time {
  font-size: 24rpx;
  color: #999;
}

.article-cover {
  margin-bottom: 30rpx;
  border-radius: 12rpx;
  overflow: hidden;
}

.article-body {
  font-size: 30rpx;
  color: #333;
  line-height: 1.8;
}

.article-body rich-text {
  display: block;
}

.loading {
  display: flex;
  justify-content: center;
  padding: 100rpx 0;
}
