.article-detail-page {
  padding-bottom: 210rpx;
}

.article-hero {
  position: relative;
  z-index: 1;
  overflow: hidden;
  margin: 32rpx 32rpx 0;
  min-height: 360rpx;
  border-radius: 26rpx;
  background:
    linear-gradient(135deg, rgba(231, 219, 199, 0.92), rgba(220, 230, 213, 0.92)),
    #f8f1e8;
  box-shadow: 0 10rpx 24rpx rgba(59, 46, 42, 0.06);
}

.article-cover {
  width: 100%;
  height: 360rpx;
  display: block;
  background: #e7dbc7;
}

.article-shade {
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  background: linear-gradient(180deg, rgba(35, 31, 26, 0.03), rgba(35, 31, 26, 0.5));
}

.article-header {
  position: absolute;
  left: 32rpx;
  right: 32rpx;
  bottom: 32rpx;
  color: #fffdf8;
}

.article-kicker {
  display: inline-block;
  height: 42rpx;
  line-height: 42rpx;
  padding: 0 18rpx;
  border-radius: 24rpx;
  background: rgba(255, 253, 248, 0.88);
  color: #5a7846;
  font-size: 22rpx;
  font-weight: 600;
}

.article-title {
  font-size: 38rpx;
  font-weight: bold;
  display: block;
  margin-top: 18rpx;
  margin-bottom: 12rpx;
  line-height: 1.4;
}

.article-time {
  font-size: 24rpx;
  color: rgba(255, 253, 248, 0.82);
}

.article-body-card {
  margin: 28rpx 32rpx 0;
  padding: 26rpx 28rpx;
  border: 1rpx solid rgba(100, 70, 40, 0.08);
  color: #6d6358;
  font-size: 29rpx;
  line-height: 1.7;
}

.article-body {
  margin: 28rpx 32rpx 0;
  padding: 34rpx 30rpx;
  border: 1rpx solid rgba(100, 70, 40, 0.08);
  font-size: 32rpx;
  color: #231f1a;
  line-height: 1.9;
}

.article-body rich-text {
  display: block;
}

.loading {
  display: flex;
  justify-content: center;
  padding: 100rpx 0;
}
