.confirm-page {
  min-height: 100vh;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx 40rpx 168rpx;
}

.confirm-card {
  position: relative;
  width: 100%;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
  padding: 64rpx 40rpx;
}

.title {
  font-size: 40rpx;
  font-weight: 700;
  color: #231f1a;
  margin-top: 12rpx;
  line-height: 1.25;
}

.desc {
  font-size: 29rpx;
  color: #7a7165;
  line-height: 1.45;
  text-align: center;
}

.confirm-btn {
  position: fixed;
  left: 40rpx;
  right: 40rpx;
  bottom: calc(28rpx + env(safe-area-inset-bottom));
  z-index: 30;
  width: auto !important;
  height: 92rpx !important;
  margin-top: 0;
  border-radius: 46rpx !important;
  font-size: 32rpx !important;
  background: #5a7846 !important;
  color: #fffdf8 !important;
}

.hint {
  font-size: 24rpx;
  color: #bbb;
  margin-top: 8rpx;
}

.success-message {
  font-size: 29rpx;
  color: #5a7846;
  text-align: center;
  margin-top: 12rpx;
  line-height: 1.6;
  max-width: 580rpx;
}

.error-message {
  font-size: 28rpx;
  color: #c06045;
  text-align: center;
  margin-top: 16rpx;
  line-height: 1.6;
  max-width: 580rpx;
}
