.confirm-page {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f5f5f5;
  padding: 40rpx;
}

.confirm-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 60rpx 40rpx;
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.08);
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-top: 16rpx;
}

.desc {
  font-size: 28rpx;
  color: #999;
}

.confirm-btn {
  width: 80% !important;
  margin-top: 40rpx;
  border-radius: 12rpx !important;
  font-size: 32rpx !important;
}

.hint {
  font-size: 24rpx;
  color: #bbb;
  margin-top: 8rpx;
}

.success-message {
  font-size: 28rpx;
  color: #07c160;
  text-align: center;
  margin-top: 12rpx;
  line-height: 1.5;
  max-width: 580rpx;
}

.error-message {
  font-size: 24rpx;
  color: #ff4d4f;
  text-align: center;
  margin-top: 16rpx;
  line-height: 1.5;
  max-width: 580rpx;
}
