.login-page {
  position: relative;
  min-height: 100vh;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  padding: 104rpx 40rpx 168rpx;
  overflow: hidden;
  background: #f8f3ea;
  color: #252118;
}

.page-pattern {
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  height: 420rpx;
  pointer-events: none;
  background:
    linear-gradient(90deg, rgba(128, 102, 66, 0.08) 1rpx, transparent 1rpx),
    linear-gradient(180deg, rgba(128, 102, 66, 0.08) 1rpx, transparent 1rpx),
    linear-gradient(180deg, #fffaf2 0%, #f8f3ea 100%);
  background-size: 36rpx 36rpx, 36rpx 36rpx, 100% 100%;
}

.page-pattern::after {
  content: '';
  position: absolute;
  right: -110rpx;
  top: 120rpx;
  width: 360rpx;
  height: 360rpx;
  background: rgba(90, 120, 70, 0.05);
  border-radius: 50%;
  opacity: 0.075;
}

.brand-section {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  min-height: 112rpx;
  margin-bottom: 44rpx;
}

.brand-logo {
  width: 96rpx;
  height: 96rpx;
  flex-shrink: 0;
  margin-right: 22rpx;
  border-radius: 24rpx;
  background: #fffaf2;
  box-shadow: 0 12rpx 26rpx rgba(82, 63, 35, 0.12);
}

.brand-copy {
  display: flex;
  flex-direction: column;
  justify-content: center;
  min-width: 0;
}

.clinic-name {
  font-size: 42rpx;
  font-weight: 700;
  line-height: 1.2;
  color: #4b3824;
}

.slogan {
  margin-top: 8rpx;
  font-size: 26rpx;
  line-height: 1.4;
  color: #7e735f;
}

.login-card {
  position: relative;
  z-index: 1;
  box-sizing: border-box;
  width: 100%;
  padding: 42rpx 36rpx 36rpx;
  border: 1rpx solid rgba(112, 92, 57, 0.14);
  border-radius: 28rpx;
  background: rgba(255, 253, 248, 0.96);
  box-shadow: 0 22rpx 58rpx rgba(73, 54, 29, 0.12);
}

.card-head {
  display: flex;
  flex-direction: column;
}

.eyebrow {
  align-self: flex-start;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: #edf4e8;
  color: #4f7041;
  font-size: 24rpx;
  line-height: 1.3;
}

.login-title {
  margin-top: 22rpx;
  font-size: 48rpx;
  font-weight: 700;
  line-height: 1.22;
  color: #282016;
}

.login-desc {
  margin-top: 18rpx;
  font-size: 30rpx;
  line-height: 1.65;
  color: #6f6555;
}

.flow-panel {
  margin-top: 34rpx;
  padding: 8rpx 0;
  border-top: 1rpx solid #eee3d3;
  border-bottom: 1rpx solid #eee3d3;
}

.flow-item {
  display: flex;
  align-items: center;
  min-height: 116rpx;
}

.flow-icon {
  width: 52rpx;
  height: 52rpx;
  flex-shrink: 0;
  margin-right: 22rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #5e7d4a;
  color: #fffdf8;
  font-size: 26rpx;
  font-weight: 700;
  line-height: 1;
}

.flow-copy {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.flow-title {
  font-size: 31rpx;
  font-weight: 600;
  line-height: 1.35;
  color: #31291d;
}

.flow-desc {
  margin-top: 6rpx;
  font-size: 26rpx;
  line-height: 1.45;
  color: #8a7e6a;
}

.agreement {
  margin-top: 34rpx;
  display: flex;
  align-items: flex-start;
}

.agreement .van-checkbox {
  flex-shrink: 0;
  margin-top: 4rpx;
}

.agreement-label {
  flex: 1;
  min-width: 0;
  margin-left: 12rpx;
  font-size: 25rpx;
  line-height: 1.6;
  color: #756b5d;
}

.link {
  color: #4f7041;
  font-weight: 600;
}

.phone-login-btn {
  position: fixed;
  left: 40rpx;
  right: 40rpx;
  bottom: calc(28rpx + env(safe-area-inset-bottom));
  z-index: 30;
  width: auto;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0;
  padding: 0;
  border: none;
  border-radius: 48rpx;
  background: #5e7d4a;
  color: #fffdf8;
  font-size: 34rpx;
  font-weight: 700;
  line-height: 1;
  text-align: center;
  -webkit-appearance: none;
}

.phone-login-btn::after {
  border: none;
}

.phone-login-btn[loading] {
  opacity: 0.78;
}

.phone-login-btn[disabled] {
  background: #cfc6b6;
  color: rgba(255, 253, 248, 0.86);
}

.login-tip {
  display: block;
  margin-top: 26rpx;
  text-align: center;
  font-size: 25rpx;
  line-height: 1.5;
  color: #8a7e6a;
}

.footer {
  position: relative;
  z-index: 1;
  margin-top: auto;
  padding-top: 36rpx;
  text-align: center;
}

.footer-text {
  font-size: 24rpx;
  line-height: 1.5;
  color: #a89b88;
}
